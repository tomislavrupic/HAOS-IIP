{
  "stage": "22_delayed_nonlocal_kernel_memory_probe",
  "description": "Base 27-run persistence-first pilot for delayed nonlocal kernel memory on the frozen projected transverse architecture.",
  "kernel_law": {
    "driver": "smoothed_local_energy_density",
    "spatial_smoothing_sigma": 4.0,
    "memory_horizon_tau": 0.25,
    "kernel_update_clamp": 0.05,
    "support_preserving": true,
    "symmetric_weights_only": true,
    "interpretation": "temporally extended and spatially distributed kernel memory without new packet species or coefficient escalation",
    "memory_classes": [
      {
        "memory_class_id": "A_single_lag_retarded",
        "label": "single-lag retarded reinforcement",
        "update_form": "K = K0 * (1 + eps * Phi(t-tau))"
      },
      {
        "memory_class_id": "B_exponential_history",
        "label": "exponential history kernel",
        "update_form": "K = K0 * (1 + eps * int exp(-s/tau) Phi(t-s) ds)"
      },
      {
        "memory_class_id": "C_window_average",
        "label": "finite-window historical averaging",
        "update_form": "K = K0 * (1 + eps * avg_{[t-tau,t]} Phi)"
      }
    ]
  },
  "parameter_policy": {
    "eps_values": {
